# OllamaDev VPS deployment — one place to set everything.
# Read by the systemd units (EnvironmentFile=) and by the setup/session scripts.
# Values are literal: systemd does NOT expand ${...} inside this file.

# The unprivileged Linux user the whole stack runs as. Created by setup.sh.
ODV_USER=ollamadev
ODV_HOME=/home/ollamadev

# The built GUI binary and the project you want it to open on launch.
# Build it once on the VPS (see README) — this is the path to the executable.
ODV_APP=/home/ollamadev/ollamadev-qt/build/ade/ollamadev-ade
ODV_WORKDIR=/home/ollamadev/projects

# Headless X display + its size. noVNC rescales in the browser, so pick whatever
# desktop area you want; 1600x900 suits a laptop, 1280x800 a phone in landscape.
DISPLAY_NUM=:10
GEOMETRY=1600x900

# Loopback-only ports. Neither is exposed to the internet directly — Caddy is the
# only public listener and it fronts noVNC.
VNC_PORT=5900
NOVNC_PORT=6080

# Ollama runs on the same box, bound to localhost. The GUI talks to it locally,
# so Ollama is never exposed publicly. Leave as-is unless you moved it.
OLLAMA_HOST=http://127.0.0.1:11434
